# Production environment — copy to .env on the VPS and fill in secrets.

DOMAIN=your-domain.com

# Database (Docker internal hostnames)
DATABASE_URL=postgresql://registerkaro:CHANGE_ME_STRONG@postgres:5432/registerkaro
POSTGRES_USER=registerkaro
POSTGRES_PASSWORD=CHANGE_ME_STRONG
POSTGRES_DB=registerkaro

# Redis
REDIS_URL=redis://redis:6379

# MinIO / S3 (internal)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=CHANGE_ME_STRONG
S3_BUCKET=registerkaro-documents
S3_REGION=us-east-1

# API
API_PORT=3001
CORS_ORIGIN=https://your-domain.com
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
ENCRYPTION_KEY=CHANGE_ME_32_HEX_CHARS
WORKER_TOKEN=CHANGE_ME_WORKER_TOKEN

# Web (baked into image at build time via docker compose build args)
NEXT_PUBLIC_API_URL=https://your-domain.com

# Worker
WORKER_CONCURRENCY=2
API_URL=http://api:3001
GST_PORTAL_URL=https://www.gst.gov.in
HEADLESS=true

# Ops defaults
OTP_MODE=manual
FILING_EMAIL=ops@example.com
FILING_MOBILE=9876543210
