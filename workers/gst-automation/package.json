{
  "name": "@registerkaro/gst-automation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "start": "dotenv -e ../../.env -- node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:part-a": "vitest run src/steps/part-a.test.ts src/page-utils.test.ts src/form-utils.test.ts"
  },
  "dependencies": {
    "@registerkaro/shared-types": "workspace:*",
    "bullmq": "^5.34.3",
    "dotenv": "^16.4.7",
    "ioredis": "^5.4.2",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "dotenv-cli": "^8.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
